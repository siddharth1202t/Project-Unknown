{
  "name": "project-unknown",
  "version": "1.0.0",
  "description": "An autonomous intelligence engine designed for independent judgment, risk evaluation, and human-centric protection. Not a servant. An observer.",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "docs",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.11.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.8.2",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "audit": "npm audit --audit-level=high",
    "deps:check": "npm outdated || true",
    "security:verify": "npm run audit && npm run typecheck && npm run lint",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/siddharth1202t/Project-Unknown.git"
  },
  "bugs": {
    "url": "https://github.com/siddharth1202t/Project-Unknown/issues"
  },
  "homepage": "https://github.com/siddharth1202t/Project-Unknown#readme",
  "keywords": [
    "ai",
    "guardian-layer",
    "risk-evaluation",
    "decision-engine",
    "typescript",
    "safety"
  ],
  "author": "Siddharth",
  "license": "MIT",
  "sideEffects": false,
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.32.0",
    "@typescript-eslint/parser": "^8.32.0",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "husky": "^9.1.7",
    "prettier": "^3.5.3",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
